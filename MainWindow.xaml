<Window x:Class="LiveCaptioner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LiveCaptioner"
        Width="960"
        Height="430"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Topmost="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid>
        <Border x:Name="CaptionSurface"
                Margin="8"
                Padding="20,14"
                CornerRadius="8"
                Background="#A6000000"
                MouseLeftButtonDown="CaptionSurface_MouseLeftButtonDown">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="设置" Click="SettingsMenuItem_Click" />
                    <MenuItem Header="新对话" Click="NewConversationMenuItem_Click" />
                    <MenuItem Header="历史记录" Click="HistoryMenuItem_Click" />
                    <MenuItem x:Name="StartStopMenuItem" Header="停止捕获" Click="StartStopMenuItem_Click" />
                    <MenuItem x:Name="ClickThroughMenuItem" Header="鼠标穿透" IsCheckable="True" Click="ClickThroughMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="退出" Click="ExitMenuItem_Click" />
                </ContextMenu>
            </Border.ContextMenu>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="StatusText"
                           Grid.Row="0"
                           Margin="0,0,0,6"
                           Foreground="#B3FFFFFF"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis" />

                <StackPanel Grid.Row="1"
                            Margin="0,2,0,14"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="PrimaryCaptionText"
                               Foreground="White"
                               FontSize="32"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               LineStackingStrategy="BlockLineHeight"
                               LineHeight="42"
                               Text="LiveCaptioner 正在启动..." />
                    <TextBlock x:Name="SecondaryCaptionText"
                               Margin="0,7,0,0"
                               Foreground="#E6FFFFFF"
                               FontSize="23"
                               FontWeight="Medium"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               LineStackingStrategy="BlockLineHeight"
                               LineHeight="31"
                               Visibility="Collapsed" />
                </StackPanel>

                <Border Grid.Row="2"
                        Padding="0,12,0,0"
                        BorderBrush="#26FFFFFF"
                        BorderThickness="0,1,0,0">
                    <ScrollViewer x:Name="InlineHistoryScrollViewer"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="InlineHistoryList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,11">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="58" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding TimestampText}"
                                                   Foreground="#80FFFFFF"
                                                   FontSize="11"
                                                   Margin="0,2,12,0" />

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding PrimaryText}"
                                                       Foreground="#E6FFFFFF"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding SecondaryText}"
                                                       Foreground="#BFFFFFFF"
                                                       FontSize="14"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="HistoryPanel"
                Width="520"
                MaxHeight="460"
                Margin="12"
                Padding="18"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                CornerRadius="8"
                Background="#F21B1B1B"
                BorderBrush="#33FFFFFF"
                BorderThickness="1"
                Visibility="Collapsed">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="历史记录"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="HistoryPathText"
                               Margin="14,3,0,0"
                               Foreground="#99FFFFFF"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    </StackPanel>

                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="新对话"
                                Padding="12,6"
                                Margin="10,0,0,0"
                                Click="NewConversationButton_Click" />
                        <ComboBox x:Name="ConversationBox"
                                  DisplayMemberPath="DisplayName"
                                  SelectionChanged="ConversationBox_SelectionChanged" />
                    </DockPanel>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,12,0,0">
                    <Button Content="刷新" Padding="14,7" Margin="0,0,8,0" Click="RefreshHistoryButton_Click" />
                    <Button Content="关闭" Padding="14,7" Click="CloseHistoryButton_Click" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="HistoryList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,0,0,10"
                                        Margin="0,0,0,10"
                                        BorderBrush="#26FFFFFF"
                                        BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TimestampText}"
                                                   Foreground="#99FFFFFF"
                                                   FontSize="11" />
                                        <TextBlock Text="{Binding PrimaryText}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0" />
                                        <TextBlock Text="{Binding SecondaryText}"
                                                   Foreground="#CCFFFFFF"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
